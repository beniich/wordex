# 🛡️ WORDEX PRODUCTION ENVIRONMENT (AETHER-PROD)
# Copy to .env.production and fill with secure credentials

# Domain & SSL
DOMAIN_NAME=wordex.com
SSL_EMAIL=admin@wordex.com

# Database (PostgreSQL)
POSTGRES_DB=wordex
POSTGRES_USER=wordex_admin
POSTGRES_PASSWORD=generate_a_secure_password_here

# Backend (FastAPI)
ENVIRONMENT=production
LOG_LEVEL=info
SECRET_KEY=generate_a_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Cache
REDIS_URL=redis://redis:6379

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://api.wordex.com

# WASP Security Protocol
WASP_ENCRYPTION_SALT=generate_a_secure_salt_here
WASP_KEY_ROTATION_INTERVAL=30 # Days
