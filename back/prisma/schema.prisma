// Wordex Multi-tenant Prisma Schema
// industrialisation pour SaaS (Cliniques / Entreprises)

generator client {
  provider = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ── Multi-tenancy ────────────────────────────────────────────────────────────

model Organisation {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo_url    String?
  
  // Abonnement
  plan        Plan     @default(FREE)
  stripe_customer_id String? @unique
  subscription_id    String? @unique
  subscription_status String? // active, trialing, canceled, etc.
  
  users       User[]
  workspaces  Workspace[]
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// ── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  username    String   @unique
  hashed_pw   String?
  avatar_url  String?
  provider    String   @default("local") // local | google | github
  provider_id String?
  
  role        Role     @default(MEMBER)
  
  organisation_id String?
  organisation    Organisation? @relation(fields: [organisation_id], references: [id])
  
  owned_workspaces Workspace[]        @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Activities
  ai_sessions  AIChatSession[]
  files        File[]
  comments     Comment[]
  saved_versions DocumentVersion[]
}

// ── Workspaces ────────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String   @default("architecture")
  color       String   @default("#894d0d")
  
  organisation_id String?
  organisation    Organisation? @relation(fields: [organisation_id], references: [id])
  
  owner_id    String
  owner       User     @relation("WorkspaceOwner", fields: [owner_id], references: [id])
  
  members     WorkspaceMember[]
  documents   Document[]
  machines    Machine[]
  production_runs ProductionRun[]
  amdec_failures  AmdecFailure[]
  webhooks    Webhook[]
  analytics_vars AnalyticsVariable[]
  files       File[]

  created_at  DateTime @default(now())
}

model WorkspaceMember {
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user_id      String
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role         String    @default("viewer") // owner | editor | viewer
  joined_at    DateTime  @default(now())

  @@id([workspace_id, user_id])
}

// ── Documents ─────────────────────────────────────────────────────────────────

model Document {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  
  parent_id    String?
  parent       Document? @relation("DocHierarchy", fields: [parent_id], references: [id])
  children     Document[] @relation("DocHierarchy")
  
  title        String   @default("Untitled")
  content      Json?
  content_text String?
  doc_type     String   @default("note") // note | spreadsheet | presentation | gantt | analytics
  
  created_by   String
  updated_by   String?
  
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  
  versions     DocumentVersion[]
  comments     Comment[]
  gantt_tasks  GanttTask[]
  gantt_resources GanttResource[]
  analytics_vars AnalyticsVariable[]
  ai_sessions  AIChatSession[]
  files        File[]
}

model DocumentVersion {
  id          String   @id @default(uuid())
  document_id String
  document    Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  content     Json?
  saved_by    String
  user        User     @relation(fields: [saved_by], references: [id])
  version     Int
  created_at  DateTime @default(now())
}

// ── Files & Attachments ───────────────────────────────────────────────────────

model File {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  document_id  String?
  document     Document? @relation(fields: [document_id], references: [id])
  
  filename     String
  storage_key  String   // MinIO key
  mime_type    String?
  size_bytes   BigInt?
  
  uploaded_by  String
  user         User     @relation(fields: [uploaded_by], references: [id])
  created_at   DateTime @default(now())
}

// ── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id          String   @id @default(uuid())
  document_id String
  document    Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  author_id   String
  author      User     @relation(fields: [author_id], references: [id], onDelete: Cascade)
  
  parent_id   String?
  parent      Comment? @relation("CommentReplies", fields: [parent_id], references: [id])
  replies     Comment[] @relation("CommentReplies")
  
  content     String
  anchor_from Int?
  anchor_to   Int?
  resolved    Boolean  @default(false)
  created_at  DateTime @default(now())
}

// ── Gantt ─────────────────────────────────────────────────────────────────────

model GanttTask {
  id           String   @id @default(uuid())
  document_id  String
  document     Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  
  parent_id    String?
  parent       GanttTask? @relation("GanttHierarchy", fields: [parent_id], references: [id])
  children     GanttTask[] @relation("GanttHierarchy")
  
  name         String
  task_type    String   @default("task") // project | task | milestone
  start_date   DateTime
  end_date     DateTime
  progress     Int      @default(0)
  priority     String   @default("medium")
  
  assignee_ids String[] @default([])
  color        String?
  position     Int      @default(0)
  is_collapsed Boolean  @default(false)
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  
  dependencies_from GanttDependency[] @relation("FromTask")
  dependencies_to   GanttDependency[] @relation("ToTask")
  resources         GanttTaskResource[]
}

model GanttDependency {
  from_task_id String
  from_task    GanttTask @relation("FromTask", fields: [from_task_id], references: [id], onDelete: Cascade)
  to_task_id   String
  to_task      GanttTask @relation("ToTask", fields: [to_task_id], references: [id], onDelete: Cascade)
  dep_type     String    @default("finish_to_start")

  @@id([from_task_id, to_task_id])
}

model GanttResource {
  id            String   @id @default(uuid())
  document_id   String
  document      Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  name          String
  resource_type String   @default("human")
  capacity      Int      @default(100)
  color         String?  @default("#A67B5B")
  status        String   @default("online")
  
  allocations   GanttTaskResource[]
}

model GanttTaskResource {
  task_id      String
  task         GanttTask @relation(fields: [task_id], references: [id], onDelete: Cascade)
  resource_id  String
  resource     GanttResource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  allocated    Int      @default(100)

  @@id([task_id, resource_id])
}

// ── Dashboard: Industry 4.0 ───────────────────────────────────────────────────

model Machine {
  id          String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  name        String
  machine_type String   @default("press")
  location    String?
  status      String   @default("online")
  
  metrics     MachineMetric[]
  production_runs ProductionRun[]
  failures    AmdecFailure[]
  
  created_at  DateTime @default(now())
}

model MachineMetric {
  id          String   @id @default(uuid())
  machine_id  String
  machine     Machine  @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  recorded_at DateTime @default(now())
  availability Int
  performance  Int
  quality      Int
  oee          Int      // Computed in logic
  shift        String   @default("morning")
}

model ProductionRun {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  machine_id   String
  machine      Machine  @relation(fields: [machine_id], references: [id])
  shift        String
  target_lots  Int      @default(250)
  actual_lots  Int      @default(0)
  date         DateTime @default(now())
}

model AmdecFailure {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  machine_id   String
  machine      Machine  @relation(fields: [machine_id], references: [id])
  mode         String
  severity     Int
  occurrence   Int
  detection    Int
  rpn          Int      // severity * occurrence * detection
  status       String   @default("open")
  created_at   DateTime @default(now())
}

// ── AI & Webhooks ─────────────────────────────────────────────────────────────

model AIChatSession {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  document_id String?
  document    Document? @relation(fields: [document_id], references: [id])
  agent       String   @default("general")
  title       String?
  messages    Json     @default("[]")
  tokens_used Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Webhook {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  name         String?
  url          String
  events       String[]
  secret       String
  active       Boolean  @default(true)
  created_at   DateTime @default(now())
  
  deliveries   WebhookDelivery[]
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  webhook_id  String
  webhook     Webhook  @relation(fields: [webhook_id], references: [id], onDelete: Cascade)
  event_type  String
  status_code Int?
  success     Boolean
  response    String?
  delivered_at DateTime @default(now())
}

model AnalyticsVariable {
  id           String   @id @default(uuid())
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  kpi_name     String
  source_doc   String?
  document     Document? @relation(fields: [source_doc], references: [id])
  cell_range   String?
  aggregation  String   @default("sum")
  created_at   DateTime @default(now())
}
